{
    "manifest_version": 3,
    "name": "TaskFlow - Minutes & Tasks",
    "version": "1.0.0",
    "description": "Automatically generate structured MoM and schedule action items from Google Meet.",
    "permissions": [
        "tabCapture",
        "scripting",
        "storage",
        "identity",
        "activeTab",
        "offscreen"
    ],
    "host_permissions": [
        "https://meet.google.com/*",
        "https://www.googleapis.com/*",
        "https://api.openai.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://meet.google.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "oauth2": {
        "client_id": "304029886607-g5vvbq0egvm513nk4imink5dfbo2nleu.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/calendar.events"
        ]
    }
}